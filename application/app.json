{
  "expo": {
    "name": "MetricBI",
    "slug": "metricbi",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "metricbi",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/app-icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-screen-images.png",
      "resizeMode": "contain",
      "backgroundColor": "#001a4d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.metricbi.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/foreground-icon.png",
        "backgroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/monochrome-icon.png"
      },
      "package": "com.metricbi.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/web-favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
